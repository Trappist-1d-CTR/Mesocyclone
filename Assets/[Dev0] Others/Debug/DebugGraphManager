using System.Collections.Generic;
using UnityEngine;

namespace MCCustom
{
    /// <summary>
    /// Manages debug graphs
    /// <para>obviously</para>
    /// </summary>
    public static class DebugGraphManager
    {
        static readonly List<DebugGraph> graphs = new();

        public static void Register(DebugGraph graph) =>
            graphs.Add(graph);

        // faux
        public static void OnGUI()
        {
            foreach (var graph in graphs)
                graph.OnGUI();
        }
    }
}